#!/usr/bin/env sh

# Util to launch the different carbon controllers
display_help() {
    echo "Usage: [name]"
    echo Supporter controllers:
	echo launcher windows power screenshot wifi run clipboard player theme
}

if [[ -z $1 ]]; then
	display_help
	exit 2
fi

pkill rofi >/dev/null 2>&1

active_file=/tmp/carbon_active_controller

current="$1"
active=$(< $active_file)

if [ "$active" = "$current" ]; then
    echo "Launched rofi controller already open, closing it."	
	: > $active_file
    exit 0
fi


echo "Launching controller:" $1
echo $current > $active_file

case $1 in
	"launcher")
		rofi -show drun -theme ~/.carbon/shell/rofi/launcher.rasi 
	;;
	"windows")
		rofi -show window -theme ~/.carbon/shell/rofi/windows.rasi
	;;
	"power")
		$CARBONPY ~/.carbon/controllers/power.py
	;;
	"screenshot") 
		$CARBONPY ~/.carbon/controllers/screenshot.py
	;;
	"wifi") 
		$CARBONPY ~/.carbon/controllers/wifi.py
	;;
	"run") 
		$CARBONPY ~/.carbon/controllers/run.py
	;;
	"clipboard") 
		cliphist list | rofi -dmenu -theme ~/.carbon/shell/rofi/clipboard.rasi -p 'Clipboard' | cliphist decode | wl-copy
	;;
	"player") 
		$CARBONPY ~/.carbon/controllers/player.py
	;;
	"theme") 
		$CARBONPY ~/.carbon/controllers/theme.py
	;;
	*)
		notify-send "Unknown controller!" $1
		echo "Unknown controller!" $1
	;;
esac

: > $active_file